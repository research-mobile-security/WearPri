        ]
      },
      "<java.io.FileWriter: * write(*)>": {
        "LibraryOnly": true,
        "TaintParamType": [
          "*"
        ],
        "TaintCheck": [
          "p*"
        ]
      },
      "<android.content.SharedPreferences$Editor: * putString(*)>": {
        "LibraryOnly": true,
        "TaintParamType": [
          "*"
        ],
        "TaintCheck": [
          "p*"
        ]
      },
      "<android.webkit.WebView: * loadUrl(*)>": {
        "LibraryOnly": true,
        "TaintParamType": [
          "java.lang.String"
        ],
        "TaintCheck": [
          "p*"
        ]
      },
      "<org.apache.http.impl.client.DefaultHttpClient: * execute(*)>": {
        "LibraryOnly": true,
        "TaintParamType": [
          "*"
