{
  "FilesDocs_FullLeak": {
    "SliceMode": true,
    "traceDepth": 12,
    "PrimTypeAsTaint": true,
    "desc": {
      "name": "FilesDocs_FullLeak",
      "detail": "Files & documents leaking to Network/IPC/File/SharedPreferences",
      "category": "ComplianceInfo",
      "complianceCategory": "FilesDocs",
      "complianceCategoryDetail": "paths, URIs, file bytes, doc contents",
      "level": "L4"
    },
    "source": {
      "Return": [
        "<android.content.ContentResolver: java.io.InputStream openInputStream(*)>",
        "<java.io.FileInputStream: int read(*)>",
        "<java.io.File: java.lang.String getPath()>",
        "<android.net.Uri: java.lang.String toString()>"
      ]
    },
    "sink": {
      "<android.webkit.WebView: * loadUrl(*)>": {
        "LibraryOnly": true,
        "TaintParamType": ["java.lang.String"],
        "TaintCheck": ["p*"]
      },
      "<org.apache.http.impl.client.DefaultHttpClient: * execute(*)>": {
        "LibraryOnly": true,
        "TaintParamType": ["*"],
        "TaintCheck": ["p*"]
      },
      "<okhttp3.Call: * enqueue(*)>": {
        "LibraryOnly": true,
        "TaintParamType": ["okhttp3.Callback"],
        "TaintCheck": ["p*"]
      },
      "<okhttp3.Call: * execute()>": {
        "LibraryOnly": true,
        "TaintCheck": ["@this"]
      },

      "<android.content.Intent: * putExtra(*)>": {
        "LibraryOnly": true,
        "TaintParamType": [
          "java.lang.String",
          "android.os.Parcelable",
          "java.io.Serializable",
          "android.os.Bundle",
          "java.lang.String[]",
          "byte[]"
        ],
        "TaintCheck": ["p*"]
      },

      "<java.io.FileOutputStream: * <init>(*)>": {
        "TaintParamType": ["java.io.File","*"],
        "TaintCheck": ["p*","@this"]
      },
      "<java.io.FileOutputStream: * write(*)>": {
        "LibraryOnly": true,
        "TaintParamType": ["*"],
        "TaintCheck": ["p*"]
      },
      "<java.io.FileWriter: * <init>(*)>": {
        "TaintParamType": ["java.io.File","*"],
        "TaintCheck": ["p*"]
      },
      "<java.io.FileWriter: * write(*)>": {
        "LibraryOnly": true,
        "TaintParamType": ["*"],
        "TaintCheck": ["p*"]
      },

      "<android.content.SharedPreferences$Editor: * putString(*)>": {
        "LibraryOnly": true,
        "TaintParamType": ["java.lang.String","*"],
        "TaintCheck": ["p*"]
      }
    }
  }
}
