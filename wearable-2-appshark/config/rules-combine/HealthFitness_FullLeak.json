{
  "HealthFitness_FullLeak": {
    "SliceMode": true,
    "traceDepth": 12,
    "PrimTypeAsTaint": true,
    "desc": {
      "name": "HealthFitness_FullLeak",
      "detail": "Health/Fitness data (heart rate, steps, sensor values, fitness history) leaking to Network/IPC/File/Log/SP",
      "category": "ComplianceInfo",
      "complianceCategory": "HealthFitness",
      "complianceCategoryDetail": "heart rate / steps / sensor arrays / history",
      "level": "L4"
    },
    "source": {
      "Field": [
        "<android.hardware.SensorEvent: float[] values>"
      ],
      "Return": [
        "<com.google.android.gms.fitness.HistoryClient: * readData(*)>",
        "<androidx.health.connect.client.records.HeartRateRecord: * get*(*)>",
        "<androidx.health.connect.client.records.StepsRecord: * get*(*)>"
      ]
    },
    "sink": {
      "<android.util.Log: int *(java.lang.String,java.lang.String)>": {
        "LibraryOnly": true,
        "TaintParamType": ["java.lang.String","java.lang.String"],
        "TaintCheck": ["p1"]
      },

      "<android.webkit.WebView: * loadUrl(*)>": {
        "LibraryOnly": true,
        "TaintParamType": ["java.lang.String"],
        "TaintCheck": ["p*"]
      },
      "<org.apache.http.impl.client.DefaultHttpClient: * execute(*)>": {
        "LibraryOnly": true,
        "TaintParamType": ["*"],
        "TaintCheck": ["p*"]
      },
      "<okhttp3.Call: * enqueue(*)>": {
        "LibraryOnly": true,
        "TaintParamType": ["okhttp3.Callback"],
        "TaintCheck": ["p*"]
      },
      "<okhttp3.Call: * execute()>": {
        "LibraryOnly": true,
        "TaintCheck": ["@this"]
      },

      "<android.content.Intent: * putExtra(*)>": {
        "LibraryOnly": true,
        "TaintParamType": [
          "java.lang.String",
          "android.os.Parcelable",
          "java.io.Serializable",
          "android.os.Bundle",
          "java.lang.String[]",
          "byte[]"
        ],
        "TaintCheck": ["p*"]
      },
      "<*: * sendBroadcast*(*)>": {
        "LibraryOnly": true,
        "TaintParamType": ["android.content.Intent","android.content.Intent[]","*"],
        "TaintCheck": ["p*"]
      },
      "<*: * sendOrderedBroadcast*(*)>": {
        "LibraryOnly": true,
        "TaintParamType": ["android.content.Intent","android.content.Intent[]","*"],
        "TaintCheck": ["p*"]
      },
      "<android.content.ContentResolver: * insert(*)>": {
        "LibraryOnly": true,
        "TaintParamType": ["*"],
        "TaintCheck": ["p*"]
      },
      "<android.content.ContentResolver: * update(*)>": {
        "LibraryOnly": true,
        "TaintParamType": ["*"],
        "TaintCheck": ["p*"]
      },

      "<java.io.FileOutputStream: * <init>(*)>": {
        "TaintParamType": ["java.io.File","*"],
        "TaintCheck": ["p*","@this"]
      },
      "<java.io.FileOutputStream: * write(*)>": {
        "LibraryOnly": true,
        "TaintParamType": ["*"],
        "TaintCheck": ["p*"]
      },
      "<java.io.FileWriter: * write(*)>": {
        "LibraryOnly": true,
        "TaintParamType": ["*"],
        "TaintCheck": ["p*"]
      },

      "<android.content.SharedPreferences$Editor: * putString(*)>": {
        "LibraryOnly": true,
        "TaintParamType": ["java.lang.String","*"],
        "TaintCheck": ["p*"]
      }
    }
  }
