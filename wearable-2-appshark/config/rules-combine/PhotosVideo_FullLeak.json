{
  "PhotosVideo_FullLeak": {
    "SliceMode": true,
    "traceDepth": 12,
    "PrimTypeAsTaint": true,
    "desc": {
      "name": "PhotosVideo_FullLeak",
      "detail": "Photos/videos (media URIs/paths) leaking to File/Network/IPC/SharedPreferences",
      "category": "ComplianceInfo",
      "complianceCategory": "PhotosVideo",
      "complianceCategoryDetail": "File/Network/IPC",
      "level": "L4"
    },
    "source": {
      "Return": [
        "<android.provider.MediaStore$Images$Media: android.net.Uri EXTERNAL_CONTENT_URI>",
        "<android.provider.MediaStore$Video$Media: android.net.Uri EXTERNAL_CONTENT_URI>",
        "<android.provider.MediaStore$Images$Media: android.net.Uri getContentUri(*)>",
        "<android.net.Uri: java.lang.String toString()>"
      ]
    },
    "sink": {
      "<java.io.FileOutputStream: * <init>(*)>": {
        "TaintCheck": ["p*","@this"]
      },
      "<java.io.FileOutputStream: * write(*)>": {
        "LibraryOnly": true,
        "TaintParamType": ["*"],
        "TaintCheck": ["p*"]
      },
      "<java.io.FileWriter: * <init>(*)>": {
        "TaintCheck": ["p*"]
      },
      "<java.io.FileWriter: * write(*)>": {
        "LibraryOnly": true,
        "TaintParamType": ["*"],
        "TaintCheck": ["p*"]
      },
      "<android.content.SharedPreferences$Editor: * putString(*)>": {
        "LibraryOnly": true,
        "TaintParamType": ["*"],
        "TaintCheck": ["p*"]
      },
      "<android.webkit.WebView: * loadUrl(*)>": {
        "LibraryOnly": true,
        "TaintParamType": ["java.lang.String"],
        "TaintCheck": ["p*"]
      },
      "<org.apache.http.impl.client.DefaultHttpClient: * execute(*)>": {
        "LibraryOnly": true,
        "TaintParamType": ["*"],
        "TaintCheck": ["p*"]
      },
      "<okhttp3.Call: * enqueue(*)>": {
        "LibraryOnly": true,
        "TaintParamType": ["okhttp3.Callback"],
        "TaintCheck": ["p*"]
      },
      "<android.content.Intent: * putExtra(*)>": {
        "LibraryOnly": true,
        "TaintParamType": [
          "java.lang.String",
          "android.os.Parcelable",
          "java.io.Serializable",
          "android.os.Bundle"
        ],
        "TaintCheck": ["p*"]
      },
      "<android.content.ContentResolver: * insert(*)>": {
        "LibraryOnly": true,
        "TaintParamType": ["*"],
        "TaintCheck": ["p*"]
      },
      "<android.content.ContentResolver: * update(*)>": {
        "LibraryOnly": true,
        "TaintParamType": ["*"],
        "TaintCheck": ["p*"]
      }
    }
  }
}
