{
  "Location_FullLeak": {
    "SliceMode": true,
    "traceDepth": 12,
    "PrimTypeAsTaint": true,
    "desc": {
      "name": "Location_FullLeak",
      "detail": "Location data (lat/lon/alt, last location) leaking to Network/IPC/Broadcast/File/Log/SP",
      "category": "ComplianceInfo",
      "complianceCategory": "Location",
      "complianceCategoryDetail": "lat/lon/alt + last known location",
      "level": "L4"
    },
    "source": {
      "Return": [
        "<android.location.Location: double getLatitude()>",
        "<android.location.Location: double getLongitude()>",
        "<android.location.Location: double getAltitude()>",
        "<android.location.LocationManager: * getLastKnownLocation(*)>",
        "<com.google.android.gms.location.FusedLocationProviderClient: * getLastLocation()>"
      ]
    },
    "sink": {
      "<android.util.Log: int *(java.lang.String,java.lang.String)>": {
        "LibraryOnly": true,
        "TaintCheck": ["p1"]
      },
      "<android.webkit.WebView: * loadUrl(*)>": {
        "LibraryOnly": true,
        "TaintParamType": ["java.lang.String"],
        "TaintCheck": ["p*"]
      },
      "<org.apache.http.impl.client.DefaultHttpClient: * execute(*)>": {
        "LibraryOnly": true,
        "TaintParamType": ["*"],
        "TaintCheck": ["p*"]
      },
      "<okhttp3.Call: * enqueue(*)>": {
        "LibraryOnly": true,
        "TaintParamType": ["okhttp3.Callback"],
        "TaintCheck": ["p*"]
      },
      "<okhttp3.Call: * execute()>": {
        "LibraryOnly": true,
        "TaintCheck": ["@this"]
      },
      "<*: * sendBroadcast*(*)>": {
        "LibraryOnly": true,
        "TaintParamType": ["android.content.Intent","android.content.Intent[]"],
        "TaintCheck": ["p*"]
      },
      "<*: * sendOrderedBroadcast*(*)>": {
        "LibraryOnly": true,
        "TaintParamType": ["android.content.Intent","android.content.Intent[]"],
        "TaintCheck": ["p*"]
      },
      "<android.content.Intent: * putExtra(*)>": {
        "LibraryOnly": true,
        "TaintParamType": [
          "java.lang.String",
          "android.os.Parcelable",
          "java.io.Serializable",
          "android.os.Bundle"
        ],
        "TaintCheck": ["p*"]
      },
      "<android.content.ContentResolver: * insert(*)>": {
        "LibraryOnly": true,
        "TaintParamType": ["*"],
        "TaintCheck": ["p*"]
      },
      "<android.content.ContentResolver: * update(*)>": {
        "LibraryOnly": true,
        "TaintParamType": ["*"],
        "TaintCheck": ["p*"]
      },
      "<java.io.FileOutputStream: * <init>(*)>": {
        "TaintCheck": ["p*","@this"]
      },
      "<java.io.FileOutputStream: * write(*)>": {
        "LibraryOnly": true,
        "TaintParamType": ["*"],
        "TaintCheck": ["p*"]
      },
      "<java.io.FileWriter: * <init>(*)>": {
        "TaintCheck": ["p*"]
      },
      "<java.io.FileWriter: * write(*)>": {
        "LibraryOnly": true,
        "TaintParamType": ["*"],
        "TaintCheck": ["p*"]
      },
      "<android.content.SharedPreferences$Editor: * putString(*)>": {
        "LibraryOnly": true,
        "TaintParamType": ["*"],
        "TaintCheck": ["p*"]
      }
    }
  }
}
