{
  "PersonalInfo_NetworkIPC": {
    "SliceMode": true,
    "traceDepth": 12,
    "PrimTypeAsTaint": true,
    "desc": {
      "name": "PersonalInfo_NetworkIPC",
      "detail": "Personal information leaking to Network/IPC/Log/File",
      "category": "ComplianceInfo",
      "complianceCategory": "PersonalInfo",
      "complianceCategoryDetail": "username/password/email/etc.",
      "level": "L4"
    },
    "source": {
      "Return": [
        "<android.widget.TextView: android.text.Editable getText()>",
        "<android.widget.EditText: android.text.Editable getText()>",
        "<android.accounts.Account: java.lang.String name()>"
      ]
    },
    "sink": {
      "<android.util.Log: int *(java.lang.String,java.lang.String)>": { "LibraryOnly": true, "TaintCheck": ["p1"] },
      "<android.webkit.WebView: * loadUrl(*)>":                        { "LibraryOnly": true, "TaintCheck": ["p*"] },
      "<org.apache.http.impl.client.DefaultHttpClient: * execute(*)>": { "LibraryOnly": true, "TaintCheck": ["p*"] },
      "<okhttp3.Call: * enqueue(*)>":                                  { "LibraryOnly": true, "TaintCheck": ["p*"] },
      "<okhttp3.Call: * execute()>":                                   { "LibraryOnly": true, "TaintCheck": ["@this"] },
      "<android.content.Intent: * putExtra(*)>":                       { "LibraryOnly": true, "TaintCheck": ["p*"] },
      "<*: * sendBroadcast*(*)>":                                      { "LibraryOnly": true, "TaintCheck": ["p*"] },
      "<android.content.ContentResolver: * insert(*)>":                { "LibraryOnly": true, "TaintCheck": ["p*"] },
      "<android.content.ContentResolver: * update(*)>":                { "LibraryOnly": true, "TaintCheck": ["p*"] },
      "<java.io.FileOutputStream: * <init>(*)>":                       { "TaintCheck": ["p*","@this"] }
    }
  }
}
